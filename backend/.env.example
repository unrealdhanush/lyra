# ---------------------------------------------------------------------------
# Supabase
# Settings > API > Project URL. Exactly this shape: no trailing slash, no
# /rest/v1 suffix. A malformed URL surfaces as PostgREST error PGRST125
# ("Invalid path specified in request URL"), which is deeply unhelpful.
SUPABASE_URL=https://abcdefghijklm.supabase.co

# Settings > API Keys > Secret keys. Bypasses RLS, so server-side only —
# never in the frontend. Older projects: the legacy service_role key works.
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxx

# ---------------------------------------------------------------------------
# OpenRouter
# Make a DEDICATED key at openrouter.ai/settings/keys, set a credit limit on
# it, and set limit_reset=daily. That cap is the real spend protection —
# size it to what you're genuinely fine losing in a day.
HOST_OPENROUTER_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxx

# ---------------------------------------------------------------------------
# App
# Your unlimited-runs pass. Activate in a browser by visiting
# https://your-app/?admin=<this value> once; deactivate with ?admin=off.
# Optional — leave unset and admin mode doesn't exist.
# NEVER put this in frontend/.env as a VITE_ var: Vite bakes those into the
# public JS bundle.
ADMIN_TOKEN=make-this-long-and-random

GATE_SALT=change-me-to-something-random
# Comma-separated, exact origins. No trailing slash.
FRONTEND_ORIGINS=http://localhost:5173,https://your-app.vercel.app

# Optional: lets Vercel preview deploys through CORS (their URLs change
# every push). Leave unset if you only ever use the production URL.
# FRONTEND_ORIGIN_REGEX=https://lyra-.*\.vercel\.app

PUBLIC_URL=https://your-app.vercel.app
